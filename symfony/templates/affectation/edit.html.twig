{% extends 'base.html.twig' %}
{% block title %}Modifier affectation{% endblock %}
{% block body %}
<h1 class="mb-4">Modifier l'affectation</h1>
<p class="text-muted">
    {{ affectation.collaborateur.prenom }} {{ affectation.collaborateur.nom }}
    — {{ affectation.restaurant.nom }} ({{ affectation.restaurant.ville }})
</p>

<div class="card shadow-sm"><div class="card-body">
    {{ form_start(form) }}
        {{ form_row(form.collaborateur) }}
        {{ form_row(form.restaurant) }}
        {{ form_row(form.fonction) }}
        {{ form_row(form.dateDebut) }}
        {{ form_row(form.dateFin) }}
        <button class="btn btn-danger">Enregistrer</button>
        <a class="btn btn-link" href="{{ path('app_collaborateur_show', {id: affectation.collaborateur.id}) }}">Annuler</a>
    {{ form_end(form) }}
</div></div>
{% endblock %}
